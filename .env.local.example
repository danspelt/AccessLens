# AccessLens Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Database ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=accesslens

# ─── Auth.js ─────────────────────────────────────────────────────────────
# Required: a random secret for encrypting JWTs and cookies (min 32 chars)
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Production / Docker (Coolify, Traefik): app trusts the Host header (default in code).
# Set to false only if you rely solely on a fixed AUTH_URL below.
# AUTH_TRUST_HOST=false

# Canonical public URL (include https). Used for OAuth callbacks and session URLs.
# Example on Coolify: https://your-service.xxx.sslip.io or your real domain
# AUTH_URL=https://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email / Magic Link (Resend) ────────────────────────────────────────
# Optional: enables "Email me a sign-in link" flow
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
