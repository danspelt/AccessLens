# AccessLens Environment Variables
# Copy this file to .env.local and replace placeholders with your real values.

# ─── Database ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=accesslens
# Atlas example (replace user, password, cluster):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.abcd123.mongodb.net/accesslens

# ─── Auth.js ─────────────────────────────────────────────────────────────
# Min 32 characters. Generate: openssl rand -base64 32
# Never use the value below in production — replace with your own secret.
# Docker/Coolify: must also be available during `docker build` (Edge middleware).
AUTH_SECRET=local-dev-only-replace-with-openssl-rand-base64-32-chars-min

# Canonical public URL (https, no trailing slash). OAuth callbacks + session URLs.
# Local: http://localhost:3000  |  Production: https://your-domain.com
AUTH_URL=http://localhost:3000

# Optional: set false only if you use a single fixed AUTH_URL and want stricter host checks.
# AUTH_TRUST_HOST=false

# Legacy alias (optional); Auth.js prefers AUTH_SECRET above.
# NEXTAUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect URI: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-replace-with-client-secret-from-google-console

# ─── Email / Magic Link (Resend) ────────────────────────────────────────
# Optional — leave key empty to disable magic-link sign-in.
RESEND_API_KEY=re_00000000000000000000000000000000
RESEND_FROM_EMAIL=AccessLens <onboarding@resend.dev>

# ─── Geocoding (Nominatim) ──────────────────────────────────────────────
# Polite User-Agent with contact — reduces throttling risk.
NOMINATIM_USER_AGENT=AccessLens (local dev; contact: you@example.com)

# ─── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Iron session (optional overrides) ──────────────────────────────────
# SESSION_COOKIE_NAME=accesslens_session
# SESSION_SECRET=another-32-char-min-secret-for-iron-session-optional
